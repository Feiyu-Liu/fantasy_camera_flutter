      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"generation_records\" (\"record_id\" TEXT NOT NULL, \"created_at\" INTEGER NOT NULL, \"updated_at\" INTEGER NOT NULL, \"pipeline_status\" TEXT NOT NULL, \"original_source_type\" TEXT NOT NULL, \"original_availability\" TEXT NOT NULL, \"result_availability\" TEXT NOT NULL, \"original_local_path\" TEXT NULL, \"original_asset_id\" TEXT NULL, \"original_captured_at\" INTEGER NULL, \"original_format\" TEXT NULL, \"original_width\" INTEGER NULL, \"original_height\" INTEGER NULL, \"original_size_bytes\" INTEGER NULL, \"original_sha256\" TEXT NULL, \"original_hash_status\" TEXT NULL, \"original_hash_error\" TEXT NULL, \"original_cleared_at\" INTEGER NULL, \"upload_session_id\" TEXT NULL, \"source_image_object_id\" TEXT NULL, \"upload_content_type\" TEXT NULL, \"upload_size_bytes\" INTEGER NULL, \"upload_sha256\" TEXT NULL, \"task_id\" TEXT NULL, \"task_status\" TEXT NULL, \"result_image_object_id\" TEXT NULL, \"result_local_cache_path\" TEXT NULL, \"result_asset_id\" TEXT NULL, \"result_saved_at\" INTEGER NULL, \"result_size_bytes\" INTEGER NULL, \"result_sha256\" TEXT NULL, \"result_hash_status\" TEXT NULL, \"result_hash_error\" TEXT NULL, \"result_is_favorite\" INTEGER NOT NULL DEFAULT 0 CHECK (\"result_is_favorite\" IN (0, 1)), \"result_favorited_at\" INTEGER NULL, \"result_favorite_feedback_submitted_at\" INTEGER NULL, \"result_negative_feedback_submitted_at\" INTEGER NULL, \"prompt_style\" TEXT NULL, \"capture_mode\" TEXT NULL, \"capture_aspect_ratio\" TEXT NULL, \"app_input_contract_id\" TEXT NULL, \"user_input_json\" TEXT NULL, \"display_snapshot_json\" TEXT NULL, \"error_code\" TEXT NULL, \"error_message\" TEXT NULL, \"failure_stage\" TEXT NULL, \"failure_retryable\" INTEGER NULL CHECK (\"failure_retryable\" IN (0, 1)), \"result_notification_seen_at\" INTEGER NULL, PRIMARY KEY (\"record_id\"));"
        }
